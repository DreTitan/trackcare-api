@page "/recolhimentos/editar/{Id:int}"
@inject IRecolhimentoService RecolhimentoService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Editar Recolhimento - HealthGo Collection</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
    Editar Recolhimento
</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_recolhimento == null)
{
    <MudAlert Severity="Severity.Error">Recolhimento não encontrado.</MudAlert>
}
else
{
    <MudPaper Elevation="2" Class="pa-4">
        <MudForm @ref="_form" @bind-IsValid="_formValid">
            <MudGrid>
                <!-- Cliente -->
                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" />
                        Informações do Cliente
                    </MudText>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_recolhimento.ClienteNome"
                                  Label="Nome do Cliente *"
                                  Required="true"
                                  RequiredError="Nome é obrigatório" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_recolhimento.ClienteContato"
                                  Label="Contato" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_recolhimento.ClienteEmail"
                                  Label="E-mail"
                                  InputType="InputType.Email" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_recolhimento.ClienteTelefone"
                                  Label="Telefone" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_recolhimento.ClientePlano"
                               Label="Plano"
                               Dense="true">
                        <MudSelectItem Value="TipoPlano.GoPremium">GoPremium</MudSelectItem>
                        <MudSelectItem Value="TipoPlano.Simples">Simples</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <!-- Equipamento -->
                <MudItem xs="12">
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Devices" Class="mr-2" />
                        Informações do Equipamento
                    </MudText>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_recolhimento.Hgid"
                                  Label="HGID *"
                                  Required="true"
                                  RequiredError="HGID é obrigatório" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_recolhimento.NumeroSerie"
                                  Label="Número de Série *"
                                  Required="true"
                                  RequiredError="Número de série é obrigatório" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_recolhimento.Modelo"
                                  Label="Modelo" />
                </MudItem>

                <!-- Tickets -->
                <MudItem xs="12">
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Class="mr-2" />
                        Tickets
                    </MudText>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_recolhimento.TicketHub"
                                  Label="Ticket HubSpot" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_recolhimento.TicketBlip"
                                  Label="Ticket BLiP" />
                </MudItem>

                <!-- Problema -->
                <MudItem xs="12">
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2" />
                        Problema e Análise
                    </MudText>
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_recolhimento.DescricaoProblema"
                                  Label="Descrição do Problema *"
                                  Required="true"
                                  RequiredError="Descrição é obrigatória"
                                  Lines="3" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_recolhimento.RelatorioN3"
                                  Label="Relatório N3 (Análise Técnica)"
                                  Lines="5" />
                </MudItem>

                <!-- Status -->
                <MudItem xs="12">
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" />
                        Status
                    </MudText>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSwitch @bind-Checked="_recolhimento.JaRecolhido"
                               Label="Equipamento já foi recolhido?"
                               Color="Color.Success" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="_recolhimento.Status"
                               Label="Status"
                               Dense="true">
                        @foreach (var status in Enum.GetValues<StatusRecolhimento>())
                        {
                            <MudSelectItem Value="status">@status.ToString().Replace("_", " ")</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <!-- Datas -->
                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_dataPrevistaColeta"
                                   Label="Previsão de Coleta" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_dataColetaReal"
                                   Label="Data de Coleta Real" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_dataPrevistaDevolucao"
                                   Label="Previsão de Devolução" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_recolhimento.Observacoes"
                                  Label="Observações"
                                  Lines="3" />
                </MudItem>

                <!-- Botões -->
                <MudItem xs="12" Class="d-flex justify-end gap-2">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               Href="@($"/recolhimentos/detalhe/{Id}")">
                        Cancelar
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="@(!_formValid || _saving)"
                               OnClick="@Salvar"
                               StartIcon="@Icons.Material.Filled.Save">
                        @(_saving ? "Salvando..." : "Salvar")
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudPaper>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Recolhimento? _recolhimento;
    private MudForm? _form;
    private bool _formValid = true;
    private bool _loading = true;
    private bool _saving = false;

    private DateTime? _dataPrevistaColeta;
    private DateTime? _dataColetaReal;
    private DateTime? _dataPrevistaDevolucao;

    protected override async Task OnInitializedAsync()
    {
        _recolhimento = await RecolhimentoService.GetByIdAsync(Id);
        if (_recolhimento != null)
        {
            _dataPrevistaColeta = _recolhimento.DataPrevistaColeta;
            _dataColetaReal = _recolhimento.DataColetaReal;
            _dataPrevistaDevolucao = _recolhimento.DataPrevistaDevolucao;
        }
        _loading = false;
    }

    private async Task Salvar()
    {
        if (_form != null && !_formValid)
            return;

        if (_recolhimento == null)
            return;

        _saving = true;

        try
        {
            _recolhimento.DataPrevistaColeta = _dataPrevistaColeta;
            _recolhimento.DataColetaReal = _dataColetaReal;
            _recolhimento.DataPrevistaDevolucao = _dataPrevistaDevolucao;

            await RecolhimentoService.UpdateAsync(_recolhimento, "Admin");
            Snackbar.Add("Recolhimento atualizado com sucesso!", Severity.Success);
            Navigation.NavigateTo($"/recolhimentos/detalhe/{Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao salvar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
