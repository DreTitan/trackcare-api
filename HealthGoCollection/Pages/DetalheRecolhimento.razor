@page "/recolhimentos/detalhe/{Id:int}"
@inject IRecolhimentoService RecolhimentoService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Recolhimento @_recolhimento?.Hgid - HealthGo Collection</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_recolhimento == null)
{
    <MudAlert Severity="Severity.Error">Recolhimento não encontrado.</MudAlert>
}
else
{
    <MudGrid>
        <MudItem xs="12">
            <MudButton Variant="Variant.Text"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       Href="/recolhimentos">
                Voltar para lista
            </MudButton>
        </MudItem>

        <MudItem xs="12" md="8">
            <!-- Header -->
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.h5">
                            <MudChip T="string" Size="Size.Medium" Color="Color.Primary" Variant="Variant.Outlined">
                                @_recolhimento.Hgid
                            </MudChip>
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-1">
                            Série: @_recolhimento.NumeroSerie
                            @if (!string.IsNullOrEmpty(_recolhimento.Modelo))
                            {
                                <span> | @_recolhimento.Modelo</span>
                            }
                        </MudText>
                    </MudItem>
                    <MudItem xs="12" md="6" Class="d-flex justify-end">
                        <div Class="text-right">
                            <StatusChip Status="@_recolhimento.Status" />
                            <MudText Typo="Typo.caption" Color="Color.Default" Class="d-block mt-1">
                                Solicitado em @_recolhimento.DataSolicitacao.ToString("dd/MM/yyyy HH:mm")
                            </MudText>
                        </div>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <!-- Timeline -->
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Timeline" Class="mr-2" />
                    Timeline do Processo
                </MudText>

                <MudTimeline TimelinePosition="TimelinePosition.Start" TimelineAlign="TimelineAlign.Start">
                    <MudTimelineItem Color="@(GetStatusColor(StatusRecolhimento.N3_Enviou))" Size="Size.Small">
                        <MudText><strong>N3 Enviou</strong></MudText>
                        <MudText Typo="Typo.caption">Processo iniciado pelo N3</MudText>
                    </MudTimelineItem>
                    <MudTimelineItem Color="@(GetStatusColor(StatusRecolhimento.Aguarda_Admin))" Size="Size.Small">
                        <MudText><strong>Aguarda Admin</strong></MudText>
                        <MudText Typo="Typo.caption">Aguardando emissão de etiqueta</MudText>
                    </MudTimelineItem>
                    <MudTimelineItem Color="@(GetStatusColor(StatusRecolhimento.Aguarda_Coleta))" Size="Size.Small">
                        <MudText><strong>Aguarda Coleta</strong></MudText>
                        <MudText Typo="Typo.caption">Aguardando transportadora</MudText>
                    </MudTimelineItem>
                    <MudTimelineItem Color="@(GetStatusColor(StatusRecolhimento.Em_Transito))" Size="Size.Small">
                        <MudText><strong>Em Trânsito</strong></MudText>
                        <MudText Typo="Typo.caption">Equipamento em transporte</MudText>
                    </MudTimelineItem>
                    <MudTimelineItem Color="@(GetStatusColor(StatusRecolhimento.Recebido_Fabrica))" Size="Size.Small">
                        <MudText><strong>Recebido na Fábrica</strong></MudText>
                        <MudText Typo="Typo.caption">Equipamento chegou em Brasília</MudText>
                    </MudTimelineItem>
                    <MudTimelineItem Color="@(GetStatusColor(StatusRecolhimento.Em_Reparo))" Size="Size.Small">
                        <MudText><strong>Em Reparo</strong></MudText>
                        <MudText Typo="Typo.caption">Manutenção em andamento</MudText>
                    </MudTimelineItem>
                    <MudTimelineItem Color="@(GetStatusColor(StatusRecolhimento.Calibracao))" Size="Size.Small">
                        <MudText><strong>Calibração</strong></MudText>
                        <MudText Typo="Typo.caption">Testes de calibração (48h)</MudText>
                    </MudTimelineItem>
                    <MudTimelineItem Color="@(GetStatusColor(StatusRecolhimento.Pronto_Devolver))" Size="Size.Small">
                        <MudText><strong>Pronto para Devolver</strong></MudText>
                        <MudText Typo="Typo.caption">Aguardando expedição</MudText>
                    </MudTimelineItem>
                    <MudTimelineItem Color="@(GetStatusColor(StatusRecolhimento.Enviado))" Size="Size.Small">
                        <MudText><strong>Enviado</strong></MudText>
                        <MudText Typo="Typo.caption">Devolução em andamento</MudText>
                    </MudTimelineItem>
                    <MudTimelineItem Color="@(GetStatusColor(StatusRecolhimento.Follow_Up))" Size="Size.Small">
                        <MudText><strong>Follow-up</strong></MudText>
                        <MudText Typo="Typo.caption">Acompanhamento: 3, 7, 15 dias</MudText>
                    </MudTimelineItem>
                    <MudTimelineItem Color="@(GetStatusColor(StatusRecolhimento.Encerrado))" Size="Size.Small" Last="true">
                        <MudText><strong>Encerrado</strong></MudText>
                        <MudText Typo="Typo.caption">Processo concluído</MudText>
                    </MudTimelineItem>
                </MudTimeline>
            </MudPaper>

            <!-- Histórico -->
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.History" Class="mr-2" />
                    Histórico de Alterações
                </MudText>

                @if (_recolhimento.HistoricoStatus.Any())
                {
                    <MudTimeline TimelinePosition="TimelinePosition.Start" TimelineAlign="TimelineAlign.Start" Reverse="true">
                        @foreach (var historico in _recolhimento.HistoricoStatus.OrderByDescending(h => h.DataAlteracao))
                        {
                            <MudTimelineItem Color="Color.Info" Size="Size.Small">
                                <MudText>
                                    <strong>@historico.StatusAnterior.ToString().Replace("_", " ")</strong>
                                    →
                                    <strong>@historico.StatusNovo.ToString().Replace("_", " ")</strong>
                                </MudText>
                                <MudText Typo="Typo.caption">
                                    @historico.DataAlteracao.ToString("dd/MM/yyyy HH:mm") |
                                    @historico.Usuario
                                </MudText>
                                @if (!string.IsNullOrEmpty(historico.Observacao))
                                {
                                    <MudText Typo="Typo.body2" Class="mt-1">
                                        @historico.Observacao
                                    </MudText>
                                }
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">Nenhuma alteração registrada.</MudAlert>
                }
            </MudPaper>
        </MudItem>

        <!-- Sidebar -->
        <MudItem xs="12" md="4">
            <!-- Cliente -->
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" />
                    Cliente
                </MudText>
                <MudField Label="Nome" DisableUnderLine="true">@_recolhimento.ClienteNome</MudField>
                @if (!string.IsNullOrEmpty(_recolhimento.ClienteContato))
                {
                    <MudField Label="Contato" DisableUnderLine="true">@_recolhimento.ClienteContato</MudField>
                }
                @if (!string.IsNullOrEmpty(_recolhimento.ClienteEmail))
                {
                    <MudField Label="E-mail" DisableUnderLine="true">@_recolhimento.ClienteEmail</MudField>
                }
                @if (!string.IsNullOrEmpty(_recolhimento.ClienteTelefone))
                {
                    <MudField Label="Telefone" DisableUnderLine="true">@_recolhimento.ClienteTelefone</MudField>
                }
                <MudChip T="string"
                         Color="@(_recolhimento.ClientePlano == TipoPlano.GoPremium ? Color.Success : Color.Default)"
                         Size="Size.Small"
                         Class="mt-2">
                    @(_recolhimento.ClientePlano == TipoPlano.GoPremium ? "GoPremium" : "Simples")
                </MudChip>
            </MudPaper>

            <!-- Tickets -->
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Class="mr-2" />
                    Tickets
                </MudText>
                <MudField Label="HubSpot" DisableUnderLine="true">@(_recolhimento.TicketHub ?? "-")</MudField>
                <MudField Label="BLiP" DisableUnderLine="true">@(_recolhimento.TicketBlip ?? "-")</MudField>
            </MudPaper>

            <!-- Problema -->
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
                    Problema
                </MudText>
                <MudText Class="white-space-pre-wrap">@_recolhimento.DescricaoProblema</MudText>
            </MudPaper>

            <!-- Relatório N3 -->
            @if (!string.IsNullOrEmpty(_recolhimento.RelatorioN3))
            {
                <MudPaper Elevation="2" Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Assessment" Class="mr-2" />
                        Relatório N3
                    </MudText>
                    <MudText Class="white-space-pre-wrap">@_recolhimento.RelatorioN3</MudText>
                </MudPaper>
            }

            <!-- Anexos -->
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.AttachFile" Class="mr-2" />
                    Anexos (@_recolhimento.Anexos.Count)
                </MudText>

                @if (_recolhimento.Anexos.Any())
                {
                    <MudList T="string" Dense="true">
                        @foreach (var anexo in _recolhimento.Anexos)
                        {
                            <MudListItem Icon="@Icons.Material.Filled.InsertDriveFile">
                                @anexo.NomeOriginal
                                <MudIconButton Icon="@Icons.Material.Filled.Download"
                                               Size="Size.Small"
                                               Class="ml-auto"
                                               Href="@($"/uploads/{anexo.CaminhoArquivo}")"
                                               Target="_blank" />
                            </MudListItem>
                        }
                    </MudList>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Dense="true">Nenhum anexo.</MudAlert>
                }
            </MudPaper>

            <!-- Ações Rápidas -->
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.FlashOn" Class="mr-2" />
                    Ações Rápidas
                </MudText>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           FullWidth="true"
                           Class="mb-2"
                           StartIcon="@Icons.Material.Filled.Edit"
                           Href="@($"/recolhimentos/editar/{_recolhimento.Id}")">
                    Editar
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Warning"
                           FullWidth="true"
                           Class="mb-2"
                           StartIcon="@Icons.Material.Filled.SwapHoriz"
                           OnClick="@(() => _showStatusDialog = true)">
                    Alterar Status
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           FullWidth="true"
                           Class="mb-2"
                           StartIcon="@Icons.Material.Filled.Print">
                    Imprimir
                </MudButton>

                <MudDivider Class="my-2" />

                <MudButton Variant="Variant.Text"
                           Color="Color.Error"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Delete">
                    Excluir
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Dialog de Status -->
    @if (_showStatusDialog)
    {
        <MudDialog @bind-IsVisible="_showStatusDialog">
            <DialogContent>
                <MudSelect @bind-Value="_novoStatus"
                           Label="Novo Status"
                           Dense="true"
                           Class="mb-4">
                    @foreach (var status in Enum.GetValues<StatusRecolhimento>())
                    {
                        <MudSelectItem Value="status">@status.ToString().Replace("_", " ")</MudSelectItem>
                    }
                </MudSelect>
                <MudTextField @bind-Value="_observacaoStatus"
                              Label="Observação"
                              Lines="3"
                              Placeholder="Opcional: adicionar uma observação sobre a mudança" />
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="@(() => _showStatusDialog = false)">Cancelar</MudButton>
                <MudButton Color="Color.Primary" OnClick="@SalvarStatus">Salvar</MudButton>
            </DialogActions>
        </MudDialog>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Recolhimento? _recolhimento;
    private bool _loading = true;
    private bool _showStatusDialog = false;
    private StatusRecolhimento _novoStatus = StatusRecolhimento.N3_Enviou;
    private string _observacaoStatus = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _recolhimento = await RecolhimentoService.GetByIdWithDetailsAsync(Id);
        if (_recolhimento != null)
        {
            _novoStatus = _recolhimento.Status;
        }
        _loading = false;
    }

    private Color GetStatusColor(StatusRecolhimento status)
    {
        if (_recolhimento == null) return Color.Default;

        if (_recolhimento.Status == status)
            return Color.Success;

        // Verificar se já passou por este status
        var allStatuses = Enum.GetValues<StatusRecolhimento>().ToList();
        var currentIndex = allStatuses.IndexOf(_recolhimento.Status);
        var statusIndex = allStatuses.IndexOf(status);

        return statusIndex < currentIndex ? Color.Success : Color.Default;
    }

    private async Task SalvarStatus()
    {
        if (_recolhimento == null) return;

        try
        {
            await RecolhimentoService.UpdateStatusAsync(_recolhimento.Id, _novoStatus, _observacaoStatus, "Admin");
            Snackbar.Add("Status atualizado com sucesso!", Severity.Success);
            _showStatusDialog = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro: {ex.Message}", Severity.Error);
        }
    }
}
