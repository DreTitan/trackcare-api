@page "/recolhimentos/novo"
@inject IRecolhimentoService RecolhimentoService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Novo Recolhimento - HealthGo Collection</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" />
    Novo Recolhimento
</MudText>

<MudPaper Elevation="2" Class="pa-4">
    <MudForm @ref="_form" @bind-IsValid="_formValid">
        <MudGrid>
            <!-- Cliente -->
            <MudItem xs="12">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" />
                    Informações do Cliente
                </MudText>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_recolhimento.ClienteNome"
                              Label="Nome do Cliente *"
                              Required="true"
                              RequiredError="Nome é obrigatório" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_recolhimento.ClienteContato"
                              Label="Contato" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_recolhimento.ClienteEmail"
                              Label="E-mail"
                              InputType="InputType.Email" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_recolhimento.ClienteTelefone"
                              Label="Telefone" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudSelect @bind-Value="_recolhimento.ClientePlano"
                           Label="Plano"
                           Dense="true">
                    <MudSelectItem Value="TipoPlano.GoPremium">GoPremium</MudSelectItem>
                    <MudSelectItem Value="TipoPlano.Simples">Simples</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12">
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Devices" Class="mr-2" />
                    Informações do Equipamento
                </MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_recolhimento.Hgid"
                              Label="HGID *"
                              Required="true"
                              RequiredError="HGID é obrigatório" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_recolhimento.NumeroSerie"
                              Label="Número de Série *"
                              Required="true"
                              RequiredError="Número de série é obrigatório" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_recolhimento.Modelo"
                              Label="Modelo"
                              Placeholder="Ex: HealthGo Air" />
            </MudItem>

            <MudItem xs="12">
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Class="mr-2" />
                    Tickets
                </MudText>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_recolhimento.TicketHub"
                              Label="Ticket HubSpot"
                              Placeholder="Ex: #44974167127" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_recolhimento.TicketBlip"
                              Label="Ticket BLiP"
                              Placeholder="Ex: #9102" />
            </MudItem>

            <MudItem xs="12">
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2" />
                    Problema e Análise
                </MudText>
            </MudItem>

            <MudItem xs="12">
                <MudTextField @bind-Value="_recolhimento.DescricaoProblema"
                              Label="Descrição do Problema *"
                              Required="true"
                              RequiredError="Descrição é obrigatória"
                              Lines="3" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField @bind-Value="_recolhimento.RelatorioN3"
                              Label="Relatório N3 (Análise Técnica)"
                              Lines="5"
                              Placeholder="Cole aqui o relatório técnico do N3..." />
            </MudItem>

            <MudItem xs="12">
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" />
                    Status de Recolhimento
                </MudText>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSwitch @bind-Checked="_recolhimento.JaRecolhido"
                           Label="Equipamento já foi recolhido?"
                           Color="Color.Success" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect @bind-Value="_recolhimento.Status"
                           Label="Status Inicial"
                           Dense="true">
                    <MudSelectItem Value="StatusRecolhimento.N3_Enviou">N3 Enviou</MudSelectItem>
                    <MudSelectItem Value="StatusRecolhimento.Aguarda_Admin">Aguarda Admin</MudSelectItem>
                    <MudSelectItem Value="StatusRecolhimento.Aguarda_Coleta">Aguarda Coleta</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12">
                <MudTextField @bind-Value="_recolhimento.Observacoes"
                              Label="Observações"
                              Lines="3" />
            </MudItem>

            <MudItem xs="12">
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.AttachFile" Class="mr-2" />
                    Anexos
                </MudText>
            </MudItem>

            <MudItem xs="12">
                <InputFile OnChange="@OnInputFileChanged" multiple accept=".pdf,.jpg,.jpeg,.png,.gif,.doc,.docx,.xls,.xlsx" />
                <MudText Typo="Typo.caption" Color="Color.Default">
                    Formatos aceitos: PDF, JPG, PNG, DOC, DOCX, XLS, XLSX
                </MudText>
            </MudItem>
        </MudGrid>

        <MudGrid Class="mt-4">
            <MudItem xs="12" Class="d-flex justify-end gap-2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Href="/recolhimentos">
                    Cancelar
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="@(!_formValid)"
                           OnClick="@Salvar"
                           StartIcon="@Icons.Material.Filled.Save">
                    Salvar
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudForm>
</MudPaper>

@code {
    private Recolhimento _recolhimento = new();
    private MudForm? _form;
    private bool _formValid = false;

    private void OnInputFileChanged(InputFileChangeEventArgs e)
    {
        // Arquivos serão processados no salvamento
        Snackbar.Add($"{e.FileCount} arquivo(s) selecionado(s)", Severity.Info);
    }

    private async Task Salvar()
    {
        if (_form != null && !_formValid)
            return;

        try
        {
            _recolhimento.CriadoPor = "Admin"; // TODO: Pegar do contexto de autenticação
            var novo = await RecolhimentoService.CreateAsync(_recolhimento, "Admin");
            Snackbar.Add("Recolhimento criado com sucesso!", Severity.Success);
            Navigation.NavigateTo($"/recolhimentos/detalhe/{novo.Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao salvar: {ex.Message}", Severity.Error);
        }
    }
}
