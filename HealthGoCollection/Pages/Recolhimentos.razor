@page "/recolhimentos"
@inject IRecolhimentoService RecolhimentoService
@inject NavigationManager Navigation

<PageTitle>Recolhimentos - HealthGo Collection</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="mr-2" />
    Recolhimentos
</MudText>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="_searchTerm"
                          Label="Buscar"
                          Placeholder="HGID, Série, Cliente, Ticket..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          DebounceInterval="300"
                          OnDebounceIntervalElapsed="@OnSearch" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudSelect @bind-Value="_statusFilter"
                       Label="Status"
                       Placeholder="Todos"
                       Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.FilterList"
                       Dense="true">
                <MudSelectItem Value="@((StatusRecolhimento?)null)">Todos</MudSelectItem>
                @foreach (var status in Enum.GetValues<StatusRecolhimento>())
                {
                    <MudSelectItem Value="@((StatusRecolhimento?)status)">@status.ToString().Replace("_", " ")</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="2" Class="d-flex align-center">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Href="/recolhimentos/novo"
                       StartIcon="@Icons.Material.Filled.Add"
                       FullWidth="true">
                Novo
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Elevation="2" Class="pa-4">
    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_recolhimentos.Count == 0)
    {
        <MudAlert Severity="Severity.Info">
            Nenhum recolhimento encontrado.
            <MudLink Href="/recolhimentos/novo" Class="ml-2">
                Criar novo recolhimento
            </MudLink>
        </MudAlert>
    }
    else
    {
        <MudTable Items="@_recolhimentos"
                  Hover="true"
                  Striped="true"
                  Dense="true"
                  RowsPerPage="15"
                  Loading="@_loading"
                  LoadingProgressColor="Color.Primary">
            <HeaderContent>
                <MudTh>HGID</MudTh>
                <MudTh>Nº Série</MudTh>
                <MudTh>Cliente</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Ticket Hub</MudTh>
                <MudTh>Ticket BLiP</MudTh>
                <MudTh>Solicitação</MudTh>
                <MudTh>Ações</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="HGID">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                        @context.Hgid
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Nº Série">@context.NumeroSerie</MudTd>
                <MudTd DataLabel="Cliente">
                    <MudText>@context.ClienteNome</MudText>
                    @if (!string.IsNullOrEmpty(context.ClienteContato))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Default">@context.ClienteContato</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Status">
                    <StatusChip Status="@context.Status" />
                </MudTd>
                <MudTd DataLabel="Ticket Hub">@context.TicketHub</MudTd>
                <MudTd DataLabel="Ticket BLiP">@context.TicketBlip</MudTd>
                <MudTd DataLabel="Solicitação">@context.DataSolicitacao.ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Ações">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                   Color="Color.Info"
                                   Size="Size.Small"
                                   Title="Ver detalhes"
                                   Href="@($"/recolhimentos/detalhe/{context.Id}")" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Warning"
                                   Size="Size.Small"
                                   Title="Editar"
                                   Href="@($"/recolhimentos/editar/{context.Id}")" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>Nenhum recolhimento encontrado</MudText>
            </NoRecordsContent>
            <LoadingContent>
                <MudText>Carregando...</MudText>
            </LoadingContent>
        </MudTable>
    }
</MudPaper>

@code {
    private List<Recolhimento> _recolhimentos = new();
    private bool _loading = true;
    private string _searchTerm = "";
    private StatusRecolhimento? _statusFilter = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _recolhimentos = await RecolhimentoService.SearchAsync(_searchTerm, _statusFilter);
        _loading = false;
    }

    private async Task OnSearch()
    {
        await LoadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }
}
