@using HealthGoCollection.Models
@using MudBlazor

<MudChip T="string"
         Color="@GetColor()"
         Size="Size.Small"
         Icon="@GetIcon()">
    @GetStatusText()
</MudChip>

@code {
    [Parameter]
    public StatusRecolhimento Status { get; set; }

    private Color GetColor() => Status switch
    {
        StatusRecolhimento.N3_Enviou => Color.Default,
        StatusRecolhimento.Aguarda_Admin => Color.Warning,
        StatusRecolhimento.Aguarda_Coleta => Color.Warning,
        StatusRecolhimento.Em_Transito => Color.Info,
        StatusRecolhimento.Recebido_Fabrica => Color.Info,
        StatusRecolhimento.Em_Reparo => Color.Secondary,
        StatusRecolhimento.Calibracao => Color.Secondary,
        StatusRecolhimento.Pronto_Devolver => Color.Info,
        StatusRecolhimento.Enviado => Color.Info,
        StatusRecolhimento.Follow_Up => Color.Tertiary,
        StatusRecolhimento.Encerrado => Color.Success,
        _ => Color.Default
    };

    private string GetIcon() => Status switch
    {
        StatusRecolhimento.N3_Enviou => Icons.Material.Filled.Send,
        StatusRecolhimento.Aguarda_Admin => Icons.Material.Filled.HourglassEmpty,
        StatusRecolhimento.Aguarda_Coleta => Icons.Material.Filled.LocalShipping,
        StatusRecolhimento.Em_Transito => Icons.Material.Filled.DirectionsCar,
        StatusRecolhimento.Recebido_Fabrica => Icons.Material.Filled.Inbox,
        StatusRecolhimento.Em_Reparo => Icons.Material.Filled.Build,
        StatusRecolhimento.Calibracao => Icons.Material.Filled.Speed,
        StatusRecolhimento.Pronto_Devolver => Icons.Material.Filled.Done,
        StatusRecolhimento.Enviado => Icons.Material.Filled.Send,
        StatusRecolhimento.Follow_Up => Icons.Material.Filled.FollowTheSigns,
        StatusRecolhimento.Encerrado => Icons.Material.Filled.CheckCircle,
        _ => Icons.Material.Filled.Help
    };

    private string GetStatusText() => Status switch
    {
        StatusRecolhimento.N3_Enviou => "N3 Enviou",
        StatusRecolhimento.Aguarda_Admin => "Aguarda Admin",
        StatusRecolhimento.Aguarda_Coleta => "Aguarda Coleta",
        StatusRecolhimento.Em_Transito => "Em Trânsito",
        StatusRecolhimento.Recebido_Fabrica => "Recebido Fábrica",
        StatusRecolhimento.Em_Reparo => "Em Reparo",
        StatusRecolhimento.Calibracao => "Calibração",
        StatusRecolhimento.Pronto_Devolver => "Pronto Devolver",
        StatusRecolhimento.Enviado => "Enviado",
        StatusRecolhimento.Follow_Up => "Follow-up",
        StatusRecolhimento.Encerrado => "Encerrado",
        _ => Status.ToString()
    };
}
