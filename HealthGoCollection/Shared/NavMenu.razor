@using MudBlazor
@using Microsoft.AspNetCore.Components.Routing

<MudNavMenu Color="Color.Inherit" Dense="true">
    <MudText Typo="Typo.caption" Class="px-4 py-2" Style="opacity: 0.7;">MENU</MudText>

    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
        Dashboard
    </MudNavLink>

    <MudNavGroup Title="Recolhimentos" Icon="@Icons.Material.Filled.Assignment" Expanded="true">
        <MudNavLink Href="/recolhimentos" Match="NavLinkMatch.All">
            <MudIcon Icon="@Icons.Material.Filled.List" Size="Size.Small" Class="mr-2" />
            Listar Todos
        </MudNavLink>
        <MudNavLink Href="/recolhimentos/novo" Match="NavLinkMatch.All">
            <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" Class="mr-2" />
            Novo Recolhimento
        </MudNavLink>
    </MudNavGroup>

    <MudNavLink Href="/clientes" Icon="@Icons.Material.Filled.People">
        Clientes
    </MudNavLink>

    <MudNavLink Href="/equipamentos" Icon="@Icons.Material.Filled.Devices">
        Equipamentos
    </MudNavLink>

    <MudDivider Class="my-2" />

    <MudText Typo="Typo.caption" Class="px-4 py-2" Style="opacity: 0.7;">RELATÓRIOS</MudText>

    <MudNavLink Href="/relatorios" Icon="@Icons.Material.Filled.Assessment">
        Relatórios
    </MudNavLink>

    <MudNavLink Href="/configuracoes" Icon="@Icons.Material.Filled.Settings">
        Configurações
    </MudNavLink>
</MudNavMenu>
